{
  "name": "@gwenjs/cli",
  "version": "0.1.0",
  "description": "GWEN Engine CLI",
  "repository": {
    "type": "git",
    "url": "https://github.com/gwenjs/cli"
  },
  "bin": {
    "gwen": "./bin.js"
  },
  "files": [
    "dist",
    "bin.js",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build && pnpm run test:coverage",
    "dev": "node bin.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "prepare": "husky",
    "docs:dev": "pnpm --filter @gwenjs/cli-docs dev",
    "docs:build": "pnpm --filter @gwenjs/cli-docs build",
    "docs:preview": "pnpm --filter @gwenjs/cli-docs preview"
  },
  "dependencies": {
    "@gwenjs/app": "^0.1.0",
    "@gwenjs/kit": "^0.2.0",
    "@gwenjs/schema": "^0.1.1",
    "@gwenjs/vite": "^0.2.0",
    "c12": "4.0.0-beta.3",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "execa": "^9.6.1",
    "jiti": "^2.6.1",
    "knitwork": "^1.3.0",
    "pathe": "^2.0.3",
    "pkg-types": "^2.3.0",
    "ts-morph": "^25.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.4",
    "husky": "^9.1.7",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.59.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
